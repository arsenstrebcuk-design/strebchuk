@code {
    private List<Dictionary<string, string>>? data;
    private string selectedFormat = "JSON";
    private string displayFormat = "";
    private string convertedResult = "";
    private string fileName = "";
    private string? statusMessage;
    private string statusClass = "alert-info";
    private void RenameColumn(string oldName, string? newName)
    {
        if (data == null || string.IsNullOrWhiteSpace(oldName) || string.IsNullOrWhiteSpace(newName))
            return;

        newName = newName.Trim();

        if (oldName == newName)
            return;

        if (data.Any(r => r.ContainsKey(newName)))
            return;

        foreach (var row in data)
        {
            if (!row.ContainsKey(oldName))
                continue;

            var value = row[oldName];
            row.Remove(oldName);
            row[newName] = value;
        }
    }
    private void ClearCell(int rowIndex, string key)
    {
        if (data == null || rowIndex < 0 || rowIndex >= data.Count) return;

        if (data[rowIndex].ContainsKey(key))
            data[rowIndex][key] = "";
    }
    private void RemoveColumn(string columnName)
    {
        if (data == null) return;

        foreach (var row in data)
        {
            if (row.ContainsKey(columnName))
                row.Remove(columnName);
        }
    }
    private void AddColumn()
    {
        if (data == null || !data.Any()) return;

        string newColumn = $"Column{data.First().Count + 1}";

        foreach (var row in data)
        {
            row[newColumn] = "";
        }
    }
    private async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        try
        {
            fileName = e.File.Name;
            using var reader = new StreamReader(e.File.OpenReadStream());
            string content = await reader.ReadToEndAsync();
            data = CsvParser.Parse(content);
            Notify("CSV успішно завантажено!", "alert-success");
            convertedResult = "";
        }
        catch { Notify("Помилка завантаження", "alert-danger"); }
    }

    private void AddRow()
    {
        if (data == null || !data.Any()) return;
        var newRow = new Dictionary<string, string>();
        foreach (var key in data.First().Keys) newRow[key] = "";
        data.Add(newRow);
    }

    private void RemoveRow(int index)
    {
        if (data != null && index >= 0 && index < data.Count)
        {
            data.RemoveAt(index);
        }
    }
    private void ConvertData()
    {
        if (data == null) return;
        try
        {
            IDataFormat format = selectedFormat == "JSON" ? new JsonFormat() : new XmlFormat();
            convertedResult = format.Serialize(data);
            displayFormat = selectedFormat;
            historyService.Add(fileName, selectedFormat, data.Count);
            Notify("Дані конвертовано!", "alert-success");
        }
        catch { Notify("Помилка конвертації", "alert-danger"); }
    }

    private async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", convertedResult);
        Notify("Скопійовано!", "alert-primary");
    }

    private async Task DownloadFile()
    {
        await JS.InvokeVoidAsync("downloadFile", $"data.{displayFormat.ToLower()}", convertedResult);
        Notify("Файл завантажується", "alert-info");
    }

    private void Notify(string msg, string clss)
    {
        statusMessage = msg;
        statusClass = clss;
        StateHasChanged();
        Task.Delay(3000).ContinueWith(_ => { statusMessage = null; InvokeAsync(StateHasChanged); });
    }

}