@page "/"
@using DataConverterApp.Interfaces
@using DataConverterApp.Models
@using DataConverterApp.Services
@using System.Collections.Generic
@inject ConversionService conversionService
@inject HistoryService historyService
@inject IJSRuntime JS

<div class="container py-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">Data Converter </h1>
        <p class="text-muted">Редагуйте CSV та конвертуйте у JSON/XML</p>
    </div>

    <div style="height: 60px;">
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert @statusClass alert-dismissible fade show shadow-sm border-0 animate__animated animate__fadeInDown" role="alert">
                @statusMessage
                <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
            </div>
        }
    </div>

    <div class="row g-4 mt-2">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 rounded-4">
                <div class="card-body p-4">
                    <h6 class="text-uppercase text-primary fw-bold mb-3 small">1. Завантаження</h6>
                    <InputFile OnChange="HandleFileSelection" class="form-control form-control-sm shadow-none" />
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 rounded-4">
                <div class="card-body p-4 text-center">
                    <h6 class="text-uppercase text-success fw-bold mb-3 small">2. Формат</h6>
                    <div class="d-flex gap-2">
                        <select @bind="selectedFormat" class="form-select form-select-sm shadow-none">
                            <option value="JSON">JSON</option>
                            <option value="XML">XML</option>
                        </select>
                        <button class="btn btn-success btn-sm px-4 fw-bold @(data == null ? "disabled" : "")" @onclick="ConvertData">
                            КОНВЕРТУВАТИ
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 rounded-4">
                <div class="card-body p-4">
                    <h6 class="text-uppercase text-secondary fw-bold mb-3 small">3. Експорт</h6>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-primary btn-sm w-100 @(string.IsNullOrEmpty(convertedResult) ? "disabled" : "")" @onclick="CopyToClipboard">Копіювати</button>
                        <button class="btn btn-outline-secondary btn-sm w-100 @(string.IsNullOrEmpty(convertedResult) ? "disabled" : "")" @onclick="DownloadFile">Скачати</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (data != null && data.Any())
    {
        <div class="card mt-5 shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="card-header editor-header border-bottom py-3 px-4 d-flex justify-content-between align-items-center">
                <h6 class="m-0 fw-bold text-dark">Редактор таблиці</h6>
               
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-primary px-3" @onclick="AddRow">+ Додати рядок</button>
                        <button class="btn btn-sm btn-success px-3" @onclick="AddColumn">+ Додати стовпець</button>
                    </div>
                </div>
            </div>
            <div class="table-responsive" style="max-height: 400px;">
            <table class="table table-hover align-middle mb-0 editor-table">
                <thead class="table-light sticky-top editor-thead">
                    <tr>
                        <th class="px-3 text-center" style="width: 50px;">#</th>

                        @foreach (var key in data.First().Keys)
                        {
                            var currentKey = key;

                            <th class="px-3 py-3 small text-uppercase">
                                <div class="d-flex align-items-center gap-2">
                                    <input class="form-control form-control-sm"
                                           value="@currentKey"
                                           @onchange="(e) => RenameColumn(currentKey, e.Value?.ToString())" />

                                    <button class="btn btn-sm btn-outline-danger border-0"
                                            title="Видалити стовпець"
                                            @onclick="() => RemoveColumn(currentKey)">
                                        ✖
                                    </button>
                                </div>
                            </th>
                        }

                        <th class="px-3 text-center" style="width: 50px;">Дія</th>
                    </tr>
                </thead>

                <tbody>
                    @for (int i = 0; i < data.Count; i++)
                    {
                        var rowIndex = i;
                        var row = data[i];

                        <tr>
                            <td class="text-center text-muted small">@(i + 1)</td>

                            @foreach (var key in row.Keys.ToList())
                            {
                                var currentKey = key;

                                <td class="px-2">
                                    <input class="form-control form-control-sm border-0 bg-light-hover editor-cell-input"
                                           @bind="row[currentKey]" />
                                </td>
                            }

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-danger border-0"
                                        @onclick="() => RemoveRow(rowIndex)">
                                    🗑
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
    }

    @if (!string.IsNullOrEmpty(convertedResult))
    {
        <div class="mt-5 mb-5 animate__animated animate__fadeIn">
            <h6 class="fw-bold text-muted mb-3">Результат (@displayFormat):</h6>
            <div class="code-wrapper shadow-lg rounded-4">
                <div class="code-top-bar d-flex justify-content-between px-4 py-2 border-bottom border-secondary">
                    <span class="text-white-50 small">output.@displayFormat.ToLower()</span>
                    <span class="badge bg-primary">READY</span>
                </div>
                <pre class="p-4 m-0 code-content">@convertedResult</pre>
            </div>
        </div>
    }
</div>

